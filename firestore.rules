rules_version = '2';

// =========================================================================
// HBL-Connect — Firestore Security Rules (multi-tenant + admin-rol + audit)
//
// Doel: elke coach kan ALLEEN data zien/wijzigen van het team waar zijn
// email in /teams/{teamId}.allowedEmails staat. De owner (Andreas) en
// optionele admins (in /teams/hbl-connect.adminEmails) kunnen daarnaast
// alle teams beheren en de audit-log lezen.
//
// Hoe deployen (1x via Firebase Console):
//   1. https://console.firebase.google.com/project/follow-up-coaches/firestore/rules
//   2. Vervang de inhoud met dit bestand
//   3. Klik "Publish"
// =========================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return request.auth.token.email.lower();
    }

    function isOwner() {
      return isSignedIn() && userEmail() == 'andreasphilips3@gmail.com';
    }

    // Admin = owner OF email staat in /teams/hbl-connect.adminEmails
    function isAdmin() {
      return isOwner()
        || (isSignedIn()
            && exists(/databases/$(database)/documents/teams/hbl-connect)
            && userEmail() in get(/databases/$(database)/documents/teams/hbl-connect).data.adminEmails);
    }

    // Lid van het team waar coachId aan hangt.
    // Voor founder-coaches wordt het home-team `hbl-connect` gebruikt; voor
    // andere coaches wordt het team uit `coaches/{coachId}.teamId` gelezen.
    function isMemberOfCoachTeam(coachId) {
      return isSignedIn() && (
        // Founder coaches → home-team
        (coachId in ['Andreas','Thalyssa','Silvia']
          && exists(/databases/$(database)/documents/teams/hbl-connect)
          && userEmail() in get(/databases/$(database)/documents/teams/hbl-connect).data.allowedEmails)
        ||
        // Externe coaches: coach-doc bevat teamId
        (exists(/databases/$(database)/documents/coaches/$(coachId))
          && exists(/databases/$(database)/documents/teams/$(get(/databases/$(database)/documents/coaches/$(coachId)).data.teamId))
          && userEmail() in get(/databases/$(database)/documents/teams/$(get(/databases/$(database)/documents/coaches/$(coachId)).data.teamId)).data.allowedEmails)
      );
    }

    // ---- /teams ----
    // Reads moeten direct verifieerbaar zijn op `resource.data.allowedEmails`
    // voor `list`-queries (rule-expansion check). Owner/admin krijgen extra
    // pad om alle teams te kunnen listen voor de Beheer-pagina.
    //
    // Schrijven: alle admins mogen teams aanmaken en bewerken, MAAR `adminEmails`
    // wijzigen mag alleen de owner (anders kan een gepromote admin zichzelf en
    // anderen verder promoten en zo de hele admin-rol-lijst overschrijven).
    // Verwijderen van het home-team `hbl-connect` is altijd geweigerd zodat
    // niemand per ongeluk of kwaadwillig de fundamentele admin-config wist.
    match /teams/{teamId} {
      allow read: if isAdmin()
        || (isSignedIn() && userEmail() in resource.data.allowedEmails);

      allow create: if isAdmin()
        // Alleen owner mag bij create al admins aanduiden
        && (isOwner() || !('adminEmails' in request.resource.data));

      allow update: if isAdmin()
        && (
          isOwner()
          // Niet-owner admins mogen alles wijzigen behalve adminEmails
          || resource.data.get('adminEmails', []) == request.resource.data.get('adminEmails', [])
        );

      allow delete: if isAdmin() && teamId != 'hbl-connect';
    }

    // ---- /coaches/{coachId}/** ----
    // Alle subcollecties (clients, inventory, appointments, ...) zijn enkel
    // toegankelijk voor leden van het team waar deze coach bij hoort.
    // Admin kan altijd lezen/schrijven om beheer/cleanup mogelijk te maken.
    match /coaches/{coachId} {
      allow read:  if isAdmin() || isMemberOfCoachTeam(coachId);
      allow write: if isAdmin() || isMemberOfCoachTeam(coachId);
    }

    match /coaches/{coachId}/{subcoll}/{docId} {
      allow read, write: if isAdmin() || isMemberOfCoachTeam(coachId);
    }

    match /coaches/{coachId}/{subcoll}/{docId}/{rest=**} {
      allow read, write: if isAdmin() || isMemberOfCoachTeam(coachId);
    }

    // ---- Klant-portaal: één klant via portalToken ----
    // Het bestaande klant-portaal werkt zonder login. Klanten zien hun eigen
    // gegevens via clientId + portalToken in de URL. Die check gebeurt nu
    // client-side; voor échte beveiliging moet die naar een Cloud Function.
    // Tot dan: laat ongeauthenticeerde reads van een individueel klantdoc
    // toe (geen list), zodat het portaal blijft werken.
    match /coaches/{coachId}/clients/{clientId} {
      allow get: if true;
    }

    // ---- /audit ----
    // Append-only log van admin-acties. Alleen admins lezen + schrijven;
    // updates/deletes zijn nooit toegelaten zodat de log immutable blijft.
    // Bij create moet `actorEmail` overeenkomen met de ingelogde gebruiker
    // zodat niemand zich kan voordoen als een andere admin.
    match /audit/{auditId} {
      allow read:   if isAdmin();
      allow create: if isAdmin()
                    && request.resource.data.actorEmail == userEmail();
      allow update, delete: if false;
    }
  }
}
